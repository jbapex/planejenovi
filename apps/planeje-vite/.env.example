# Supabase (obrigatório para a app em dev e no build de produção)
# Dev: copie para .env  |  VPS build: use .env.production.local (não commitar)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key

# Opcional: service worker (predefinição: desligado)
# VITE_ENABLE_SW=true

# Supabase — anon key obrigatória no build de produção (VPS: .env.production.local)
# URL opcional: se vazio, a app usa o host do browser (útil para vários domínios no mesmo Nginx).
# VITE_SUPABASE_URL=https://seu-dominio.com
VITE_SUPABASE_ANON_KEY=sua-anon-key

# Opcional: service worker (predefinição: desligado)
# VITE_ENABLE_SW=true
